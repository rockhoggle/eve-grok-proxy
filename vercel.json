{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/sinewave.space.scripting.txt",
      "dest": "/sinewave.space.scripting.txt"
    },
    {
      "src": "/ask",
      "dest": "/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}