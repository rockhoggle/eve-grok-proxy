{
  "version": 2,
  "builds": [
    {
      "src": "api/ask.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/ask",
      "dest": "/api/ask.js"
    },
    {
      "src": "/sinewave.space.scripting.txt",
      "dest": "/public/sinewave.space.scripting.txt"
    }
  ]
}